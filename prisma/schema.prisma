generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreType {
  FOOD
  RETAIL
  SERVICES
  GAS_WATER
  GENERAL
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  store     Store?
  createdAt DateTime @default(now())
}

model Store {
  id                       String          @id @default(uuid())
  name                     String
  evolutionInstanceName    String?
  evolutionConnectionState String          @default("DISCONNECTED")
  phoneNumber              String?
  logoUrl                  String?
  userId                   String?         @unique
  user                     User?           @relation(fields: [userId], references: [id])
  products                 Product[]
  categories               Category[]
  botConfig                BotConfig?
  messages                 BotMessage[]
  orders                   Order[]
  inventoryItems           InventoryItem[]
  stockExpiries            StockExpiry[]
  suppliers                Supplier[]
  purchases                Purchase[]
  transactions             FinancialTransaction[]
  acceptsPickup            Boolean         @default(true)
  acceptsLocal             Boolean         @default(true)
  theme                    String          @default("amber-dark")
  type                     StoreType       @default(GENERAL)
  cnpj                     String?
  stateRegistration        String?
  taxRegime                String?         @default("Simples Nacional")
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model Product {
  id                    String               @id @default(cuid())
  storeId               String
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId            String?
  category              Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name                  String
  price                 Float
  emoji                 String               @default("🛍️")
  imageUrl              String?
  active                Boolean              @default(true)
  isTracked             Boolean              @default(false)
  linkedInventoryItemId String?
  linkedInventoryItem   InventoryItem?       @relation("ProductLinkedItem", fields: [linkedInventoryItemId], references: [id], onDelete: SetNull)
  ingredients           ProductIngredient[]
  options               Json?
  ncm                   String?
  cfop                  String?
  cest                  String?
  icmsRate              Float?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  emoji     String    @default("🛍️")
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model BotConfig {
  id             String   @id @default(cuid())
  storeId        String   @unique
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  welcomeMessage String   @default("Olá! Seja bem-vindo.")
  requireKeyword Boolean  @default(false)
  keyword        String   @default("@hello")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String?
  address       String
  items         Json
  total         Float
  paymentMethod    String
  needChange       Boolean  @default(false)
  changeFor        Float?
  deliveryMethod   String   @default("DELIVERY")
  localIdentifier  String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
}

model BotMessage {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fromPhone String
  fromName  String?
  text      String
  direction String
  createdAt DateTime @default(now())
}

model InventoryItem {
  id            String              @id @default(cuid())
  storeId       String
  store         Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  unit          String              @default("UN")
  currentStock  Float               @default(0)
  minStock      Float               @default(0)
  costPrice     Float               @default(0)
  ingredients   ProductIngredient[]
  linkedProducts Product[]          @relation("ProductLinkedItem")
  purchaseItems PurchaseItem[]
  stockExpiries StockExpiry[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model StockExpiry {
  id              String        @id @default(cuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  batchName       String?
  quantity        Float         @default(0)
  expirationDate  DateTime
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Supplier {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  cnpj      String?
  purchases Purchase[]
  createdAt DateTime   @default(now())
}

model Purchase {
  id            String                 @id @default(cuid())
  storeId       String
  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  issueDate     DateTime?
  totalAmount   Float
  items         PurchaseItem[]
  transactions  FinancialTransaction[]
  createdAt     DateTime               @default(now())
}

model PurchaseItem {
  id              String         @id @default(cuid())
  purchaseId      String
  purchase        Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  name            String
  sku             String?
  quantity        Float
  unitPrice       Float
  totalPrice      Float
}

model FinancialTransaction {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type        String
  status      String    @default("PENDING")
  description String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  purchaseId  String?
  purchase    Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProductIngredient {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Float

  @@unique([productId, inventoryItemId])
}
